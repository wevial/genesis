---
// The landing page: a fixed WebGL nebula with the HUD content layer on top.
// Sections are placed along the 820vh scroll journey so each lands in the
// right part of the sky: hero in the nebula, projects in the night sky,
// contact against the dawn, and the journey ends on a fogged-in shore —
// a photograph that scrolls up into view out of the shader's fog keyframe.
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import shorePhoto from '../assets/shore-fog.jpg';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', timeZone: 'UTC' });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ko Vial</title>
    <meta name="description" content="Full-stack engineer, eight years in. Founding engineer at Relos." />
    <meta property="og:title" content="Ko Vial" />
    <meta property="og:description" content="Full-stack engineer, eight years in. Founding engineer at Relos." />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌌</text></svg>"
    />
  </head>
  <body>
    <canvas id="gl"></canvas>

    <main>
      <section id="hero">
        <div class="panel reveal">
          <h1>Ko Vial</h1>
          <p class="tagline">Full-stack engineer, eight years in.<br />Founding engineer at <a href="https://relos.com">Relos</a>.</p>
          <span class="readout">LAT 37.77 · LON −122.42 · SECTOR: NEBULA</span>
        </div>
        <p class="scroll-cue reveal">scroll — it gets brighter ↓</p>
      </section>

      <div class="void" aria-hidden="true"></div>

      <section id="projects">
        <h2 class="reveal">Projects</h2>
        <div class="wrap reveal">
          <svg id="constellation" viewBox="0 0 800 460" aria-label="Projects rendered as a constellation">
            <g id="edges"></g>
            <g id="stars"></g>
          </svg>
          <div id="proj-card" class="panel" aria-live="polite"></div>
        </div>
      </section>

      <div class="void small" aria-hidden="true"></div>

      <section id="writing">
        <h2 class="reveal">Writing</h2>
        <ul class="posts panel reveal">
          {
            posts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
              </li>
            ))
          }
        </ul>
        <p class="more reveal"><a href="/blog/">all posts →</a></p>
      </section>

      <div class="void smaller" aria-hidden="true"></div>

      <section id="contact">
        <h2 class="reveal">Elsewhere</h2>
        <div class="panel dawn reveal">
          <div class="links">
            <a href="mailto:ko@relos.com">ko@relos.com</a>
            <a href="https://github.com/wevial">github/wevial</a>
          </div>
          <div class="timeline">
            <div><span>now</span><span>Founding engineer, Relos</span></div>
            <div><span>before</span><span>Eight years of full-stack work.</span></div>
          </div>
        </div>
      </section>

      <div class="void preshore" aria-hidden="true"></div>

      <footer id="shore">
        <Image
          id="shore-photo"
          src={shorePhoto}
          widths={[1280, 2560, 3840]}
          sizes="100vw"
          alt=""
          aria-hidden="true"
        />
        <p class="readout landfall reveal">ALT 0 M · RUBY BEACH, WA · TRANSMISSION ENDS</p>
        <p class="readout credit reveal">PHOTO BY ME · JUL 2026</p>
      </footer>
    </main>

    <script>
      import '../scripts/main.js';
      import '../scripts/ui.js';
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    /* the glass dial — crank blur/tint up toward "cockpit", down toward bare HUD */
    --glass-blur: 7px;
    --glass-tint: rgba(4, 10, 9, 0.22);
    --frame: rgba(160, 200, 190, 0.35);
    --frame-ghost: rgba(160, 200, 190, 0.12);
    --ink: #d5efe8;
    --ink-dim: #a9c9c0;
    --readout: #8fc4b7;
    --readout-dim: #6e9a90;
    --mono: 'SF Mono', Menlo, Consolas, monospace;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: #050113; /* pre-GL paint, matches space top of gradient */
    overflow-x: hidden;
    color: var(--ink);
    font-family: var(--mono);
  }
  #gl {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    display: block;
    touch-action: pan-y;
    z-index: 0;
  }

  main { position: relative; z-index: 1; }
  section, #shore { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 10vh 7vw; }
  .void { height: 150vh; }
  .void.small { height: 30vh; }
  .void.smaller { height: 40vh; }
  #contact { min-height: 130vh; }
  .void.preshore { height: 70vh; }
  /* The shore: the photograph is section-anchored, so the beach scrolls up
     into view out of the shader's fog — the feathered top edge is what
     blends it into the sky. */
  #shore { position: relative; justify-content: flex-end; padding-bottom: 7vh; }
  #shore-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 65%;
    pointer-events: none;
    mask-image: linear-gradient(to bottom, transparent, #000 22%);
    -webkit-mask-image: linear-gradient(to bottom, transparent, #000 22%);
  }
  #shore .landfall { position: relative; color: rgba(222, 234, 236, 0.8); margin: 0; }
  #shore .credit { position: relative; color: rgba(200, 214, 216, 0.5); margin: 0.5rem 0 0; }

  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.9s ease, transform 0.9s ease; }
  .reveal.in { opacity: 1; transform: none; }

  /* --- HUD panel: light glass, offset double frame --- */
  .panel {
    position: relative;
    border: 1px solid var(--frame);
    border-radius: 2px;
    padding: 2rem 2.4rem;
    background: var(--glass-tint);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
  }
  .panel::before {
    content: '';
    position: absolute;
    inset: -1px;
    border: 1px solid var(--frame-ghost);
    border-radius: 2px;
    transform: translate(5px, 5px);
    pointer-events: none;
  }

  h1 {
    font-size: clamp(1.8rem, 4.5vw, 3rem);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink);
  }
  h1::before { content: '// '; opacity: 0.5; }
  .tagline {
    margin-top: 1.1rem;
    font-size: 0.85rem;
    line-height: 1.9;
    color: var(--ink-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .readout {
    display: block;
    margin-top: 1.4rem;
    font-size: 0.7rem;
    color: var(--readout-dim);
    letter-spacing: 0.12em;
  }
  h2 {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--readout);
    margin-bottom: 2.2rem;
  }
  h2::after { content: ' ───────────'; opacity: 0.35; }
  a { color: inherit; text-decoration: none; border-bottom: 1px dashed rgba(143, 196, 183, 0.5); }
  a:hover { color: #fff; border-bottom-color: rgba(255, 255, 255, 0.7); }

  #hero { min-height: 100vh; }
  #hero .panel { max-width: 40rem; }
  .scroll-cue {
    margin-top: 9vh;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--readout);
    opacity: 0.75;
  }

  /* --- constellation --- */
  #projects .wrap { display: grid; grid-template-columns: minmax(0, 1.4fr) minmax(260px, 1fr); gap: 3rem; align-items: center; }
  @media (max-width: 820px) { #projects .wrap { grid-template-columns: 1fr; } }
  #constellation { width: 100%; height: auto; overflow: visible; }
  #constellation .edge { stroke: rgba(143, 196, 183, 0.3); stroke-width: 1; stroke-dasharray: 3 4; }
  #constellation .star-dot { fill: #bfe8dc; cursor: pointer; }
  #constellation .star-halo { fill: none; stroke: rgba(191, 232, 220, 0); stroke-width: 1; transition: stroke 0.25s ease; }
  #constellation g.star:hover .star-dot, #constellation g.star.sel .star-dot { fill: #fff; }
  #constellation g.star:hover .star-halo, #constellation g.star.sel .star-halo { stroke: rgba(191, 232, 220, 0.5); }
  #constellation g.star:focus-visible { outline: 1px dashed var(--readout); outline-offset: 4px; }
  #constellation .star-label {
    fill: #a9d4c8;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
  }
  #proj-card { min-height: 12rem; }
  #proj-card h3 { font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.14em; }
  #proj-card p { margin-top: 0.7rem; font-size: 0.85rem; line-height: 1.8; color: var(--ink-dim); }
  #proj-card .meta { font-size: 0.7rem; color: var(--readout-dim); text-transform: uppercase; letter-spacing: 0.1em; }

  /* --- writing --- */
  .posts { list-style: none; max-width: 36rem; }
  .posts li { padding: 0.75rem 0; display: flex; justify-content: space-between; gap: 1.5rem; align-items: baseline; font-size: 0.9rem; }
  .posts li::before { content: '> '; opacity: 0.5; }
  .posts li + li { border-top: 1px solid var(--frame-ghost); }
  .posts time { color: var(--readout-dim); font-size: 0.7rem; white-space: nowrap; text-transform: uppercase; }
  .more { margin-top: 1.4rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; }

  /* --- contact: sits against the dawn, so its glass runs darker and the
         section heading flips to dark ink for the bright sky --- */
  #contact h2 { color: rgba(10, 30, 26, 0.78); }
  #contact .panel.dawn {
    max-width: 38rem;
    background: rgba(4, 10, 9, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  #contact .links { display: flex; gap: 2rem; flex-wrap: wrap; margin-bottom: 2.2rem; font-size: 0.9rem; }
  .timeline div { padding: 0.55rem 0; display: grid; grid-template-columns: 6.5rem 1fr; gap: 1rem; font-size: 0.85rem; line-height: 1.7; }
  .timeline span:first-child { color: var(--readout-dim); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em; padding-top: 0.25em; }

  @media (prefers-reduced-motion: reduce) {
    .reveal { transition: none; opacity: 1; transform: none; }
  }

  /* Static CSS fallback when WebGL2/float rendering is unavailable */
  body.no-gl #gl { display: none; }
  body.no-gl {
    background: linear-gradient(
      to bottom,
      #050113 0%, #0a0824 8%, #0a1128 21%, #16294f 38%,
      #2b3a67 49%, #b96a8c 57%, #ff9e6b 62%, #6ab7f0 71%,
      #d9f1fe 79%, #d3dbe1 90%, #c8ced3 100%
    );
    background-attachment: scroll;
    background-size: 100% 820vh;
  }
</style>
