---
// HUD-styled shell for blog pages, matching the landing page's content layer.
interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌌</text></svg>"
    />
  </head>
  <body>
    <main>
      <nav><a href="/">← home</a> · <a href="/blog/">blog</a></nav>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --frame: rgba(160, 200, 190, 0.35);
    --frame-ghost: rgba(160, 200, 190, 0.12);
    --ink: #d5efe8;
    --ink-dim: #a9c9c0;
    --readout: #8fc4b7;
    --readout-dim: #6e9a90;
    --mono: 'SF Mono', Menlo, Consolas, monospace;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: #060b0a;
    color: var(--ink);
    font-family: var(--mono);
    line-height: 1.8;
  }
  main { max-width: 44rem; margin: 0 auto; padding: 3rem 1.25rem 6rem; }
  nav {
    margin-bottom: 3.5rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }
  a { color: inherit; text-decoration: none; border-bottom: 1px dashed rgba(143, 196, 183, 0.5); }
  a:hover { color: #fff; border-bottom-color: rgba(255, 255, 255, 0.7); }
  h1 {
    font-size: 1.5rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }
  h1::before { content: '// '; opacity: 0.5; }
  h2, h3 { font-weight: 500; letter-spacing: 0.06em; margin: 2.2rem 0 0.75rem; color: var(--ink); }
  p, ul, ol { margin: 0.9rem 0; font-size: 0.92rem; color: var(--ink-dim); }
  li { margin-left: 1.2rem; }
  pre {
    margin: 1.2rem 0;
    padding: 1rem 1.2rem;
    border: 1px solid var(--frame-ghost);
    border-radius: 2px;
    overflow-x: auto;
    font-size: 0.85rem;
  }
  code { font-family: var(--mono); }
  time { color: var(--readout-dim); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em; }
  blockquote { border-left: 1px solid var(--frame); padding-left: 1.2rem; margin: 1.2rem 0; }
</style>
